{
  "name": "XAUUSD 1-Minute Momentum Ignition",
  "description": "Highest-frequency seed. Scalps 1-minute momentum bursts: enters long when close is above EMA(9) with RSI in a strong-momentum zone and above-average volume. Very sensitive to the cost model — if edge disappears under XAUUSDSpreadCost with $0.30 spread, the edge was an artifact of ignoring spread. Used as the canary.",
  "symbol": "XAUUSD",
  "timeframe": "1m",
  "rules": {
    "long_entry": [
      {"indicator": "close", "operator": ">", "ref": "ema_9"},
      {"indicator": "ema_9", "operator": ">", "ref": "ema_20"},
      {"indicator": "rsi_14", "operator": ">", "value": 60},
      {"indicator": "rsi_14", "operator": "<", "value": 80},
      {"indicator": "volume", "operator": ">", "ref": "volume_sma_20"}
    ],
    "long_exit": [
      {"indicator": "close", "operator": "crosses_below", "ref": "ema_9"}
    ],
    "short_entry": [
      {"indicator": "close", "operator": "<", "ref": "ema_9"},
      {"indicator": "ema_9", "operator": "<", "ref": "ema_20"},
      {"indicator": "rsi_14", "operator": "<", "value": 40},
      {"indicator": "rsi_14", "operator": ">", "value": 20},
      {"indicator": "volume", "operator": ">", "ref": "volume_sma_20"}
    ],
    "short_exit": [
      {"indicator": "close", "operator": "crosses_above", "ref": "ema_9"}
    ]
  },
  "risk_management": {
    "stop_loss_pct": 0.15,
    "take_profit_pct": 0.25,
    "position_size_pct": 1.0,
    "max_positions": 1
  },
  "session_config": {
    "allowed_sessions": ["LONDON_OPEN", "NY_AM"]
  }
}
